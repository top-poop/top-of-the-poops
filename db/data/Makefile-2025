.PHONY: load-edm-2025
load-edm-2025: load_edm_2025.sql $(DOWNLOAD)/edm-2025/edm-consolidated.csv
	$(PSQL) -f $<


EDM_WALES_2025=$(DOWNLOAD)/edm-wales-2025
EDM_WALES_2025_XLS=$(wildcard $(EDM_WALES_2025)/*.xlsx)
EDM_WALES_2025_CSVS=$(EDM_WALES_2025_XLS:.xlsx=.csv)

wales-2025-clean:
	rm $(EDM_WALES_2025)/*.csv

$(EDM_WALES_2025)/edm-emergency.csv: $(EDM_WALES_2025)/edm-emergency.xlsx
	$(XLSX2CSV) -s 1 $< $@ 2> /dev/null

$(EDM_WALES_2025)/edm-emergency-2.csv: $(EDM_WALES_2025)/edm-emergency-2.xlsx
	$(XLSX2CSV) -s 1 $< $@ 2> /dev/null

$(EDM_WALES_2025)/edm-unpermitted.csv: $(EDM_WALES_2025)/edm-unpermitted.xlsx
	$(XLSX2CSV) -s 1 $< $@ 2> /dev/null

$(EDM_WALES_2025)/edm-storm.csv: $(EDM_WALES_2025)/edm-storm.xlsx
	$(XLSX2CSV) -s 1 $< $@ 2> /dev/null

$(EDM_WALES_2025)/edm-annual.csv: $(EDM_WALES_2025)/edm-annual.xlsx
	$(XLSX2CSV) -s 1 $< $@ 2> /dev/null


returns: $(EDM_2025_RETURNS) $(EDM_WALES_2025_CSVS)



$(EDM_WALES_2025)/edm-consolidated.csv: process_edms_2025_wales.py $(EDM_WALES_2025_CSVS)
	$(PYTHON) process_edms_2025_wales.py \
			--storm $(EDM_WALES_2025)/edm-storm.csv \
			--emergency $(EDM_WALES_2025)/edm-emergency.csv \
			--emergency-2 $(EDM_WALES_2025)/edm-emergency-2.csv \
			--annual $(EDM_WALES_2025)/edm-annual.csv \
			--england $(DOWNLOAD)/edm-2025/edm-consolidated.csv $@


consolidated: $(DOWNLOAD)/edm-2025/edm-consolidated.csv $(EDM_WALES_2025)/edm-consolidated.csv

