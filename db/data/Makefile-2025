
DOWNLOAD=download

ROOT_DIR:=$(shell dirname $(realpath $(firstword $(MAKEFILE_LIST))))

#Don't care about this.. its just a local database
export PGPASSWORD=docker
PGHOST ?=localhost
PGPORT ?=5432
PSQL=psql -v ON_ERROR_STOP=1 -p $(PGPORT) -h $(PGHOST) -d gis -U docker -q --pset=pager=off
CURL=curl --fail --silent
PYTHON=../../../totp/venv/bin/python3
XLSX2CSV=../../venv/bin/xlsx2csv -e -i
OGR2OGR=ogr2ogr -nlt PROMOTE_TO_MULTI -f PGDump -t_srs "EPSG:4326"


# jump through hoops to make a filename with no spaces
$(DOWNLOAD)/edm-2025/all.xlsx:
	echo "$@ Should exist!"
	exit 1


EDM_2025_NAMES=anglian dcww northumbrian severn-trent south-west southern thames united wessex yorkshire
EDM_2025_RETURNS=$(foreach name,$(EDM_2025_NAMES),$(DOWNLOAD)/edm-2025/company/$(name).csv)

$(DOWNLOAD)/edm-2025/company/anglian.csv: $(DOWNLOAD)/edm-2025/all.xlsx
	mkdir -p $(dir $@)
	$(XLSX2CSV) -s 2 $< $@ #2> /dev/null

